@page "/Blinds"
@using System.Text.Json
@using global::NetDaemon.HassModel
@using global::NetDaemon.HassModel.Entities
@using Homer.NetDaemon.Channels
@using Homer.NetDaemon.Components.Components
@using Homer.NetDaemon.Entities
@inject SwitchEntities SwitchEntities
@inject InputTextEntities InputTextEntities
@implements IDisposable
@rendermode InteractiveServer

<div class="d-flex flex-column vh-100 vw-100 overflow-hidden" style="background-color: #F8FDFF; font-family: 'Roboto', 'Noto Sans SC', sans-serif;">
    <!-- Top Action Bar (Balcony Lights Toggle) -->
    <div class="d-flex p-4 align-items-center justify-content-center" style="height: 15dvh;">
        <button class="btn d-flex align-items-center justify-content-center gap-2 fw-bold fs-5"
                style="height: 64px; min-width: 200px; border-radius: 32px; background-color: @(BalconyLightsIsOn ? "#FDF2CE" : "#E1E2E8"); color: @(BalconyLightsIsOn ? "#5A4C1F" : "#44474E"); border: none; transition: background-color 0.2s, box-shadow 0.2s; box-shadow: @(BalconyLightsIsOn ? "0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24)" : "none");"
                @onclick="ToggleLights">
            <i class="fa-solid fa-lightbulb"></i>
            @(BalconyLightsIsOn ? "阳台灯" : "阳台灯")
        </button>
    </div>

    <!-- Blinds Selector (Material Segmented Buttons / Chips style) -->
    <div class="d-flex justify-content-center gap-3 p-2" style="height: 15dvh;">
        @for (int i = 0; i < 3; i++)
        {
            var idx = i;
            var isSelected = _selectedBlinds.Contains(idx);
            <div class="position-relative">
                <input type="checkbox" class="btn-check" id="blind-@idx" autocomplete="off"
                       checked="@isSelected" @onchange="@(e => ToggleSelection(idx, e.Value))">
                <label class="btn d-flex justify-content-center align-items-center fw-bold"
                       for="blind-@idx"
                       style="width: 72px; height: 72px; font-size: 1.5rem; transition: all 0.2s ease-in-out; border-radius: 20px; background-color: @(isSelected ? "#C2E7FF" : "#E1E2E8"); color: @(isSelected ? "#001D35" : "#44474E"); border: none; box-shadow: @(isSelected ? "0 1px 3px rgba(0,0,0,0.12), 0 1px 2px rgba(0,0,0,0.24)" : "none");">
                    @(idx + 1)
                </label>
            </div>
        }
    </div>

    <!-- Slider Area -->
    <div class="flex-grow-1 d-flex justify-content-center p-3 pb-5" style="height: 70dvh;">
        <HomeBalconySlider SelectedBlinds="@_selectedBlinds"
                           BlindPositions="@BlindsPositions"
                           OnPositionSet="HandlePositionSet" />
    </div>
</div>

@code {
    private IDisposable? _lightsDisposable;
    private IDisposable? _blindsStateDisposable;
    private List<int> _selectedBlinds = [0, 1, 2];
    private bool _isInitialized;

    private bool BalconyLightsIsOn
    {
        get
        {
            if (!_isInitialized) return false;
            try
            {
                return SwitchEntities.BalconyLights.IsOn();
            }
            catch
            {
                return false;
            }
        }
    }

    private List<double> BlindsPositions
    {
        get
        {
            if (!_isInitialized) return [0, 0, 0];
            try
            {
                return JsonSerializer.Deserialize<List<double>>(InputTextEntities.BalconyBlindsState.State ?? "[0,0,0]") ?? [0, 0, 0];
            }
            catch
            {
                return [0, 0, 0];
            }
        }
    }

    protected override void OnInitialized()
    {
        try
        {
            _lightsDisposable = SwitchEntities.BalconyLights.StateChanges().SubscribeAsync(async _ => { await InvokeAsync(StateHasChanged); });
            _blindsStateDisposable = InputTextEntities.BalconyBlindsState.StateChanges().SubscribeAsync(async _ => { await InvokeAsync(StateHasChanged); });
            _isInitialized = true;
        }
        catch
        {
            // Ignore during initial pre-render or if HA is not connected
        }
    }

    private void ToggleLights()
    {
        try
        {
            SwitchEntities.BalconyLights.Toggle();
        }
        catch { /* ignored */ }
    }

    private void ToggleSelection(int index, object? isChecked)
    {
        bool val = (bool?)isChecked ?? false;
        if (val && !_selectedBlinds.Contains(index))
        {
            _selectedBlinds.Add(index);
        }
        else if (!val && _selectedBlinds.Contains(index))
        {
            _selectedBlinds.Remove(index);
        }
    }

    private async Task HandlePositionSet(double targetPosition)
    {
        if (_selectedBlinds.Count == 0) return;
        await BalconyBlindsChannel.Channel.Writer.WriteAsync(new BalconyBlindCommand(BalconyBlindAction.GoToPosition, _selectedBlinds.ToList(), targetPosition));
    }

    public void Dispose()
    {
        _lightsDisposable?.Dispose();
        _blindsStateDisposable?.Dispose();
    }
}
