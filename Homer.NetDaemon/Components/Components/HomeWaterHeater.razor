@using System.Reactive.Linq
@using global::NetDaemon.HassModel.Entities
@using Homer.NetDaemon.Entities
@using Homer.NetDaemon.Services

@rendermode InteractiveServer
@implements IDisposable

<div class="d-flex flex-column justify-content-center align-items-center bg-white rounded-3 p-2 shadow-sm" style="flex: 1;">
    @if (Switches.WaterHeaterSwitch.IsOn())
    {
        <span class="fs-2 text-danger fw-bold">开</span>
        <span class="fs-6 text-muted">热水器</span>
        @if (RemainingTime is { } remainingTime)
        {
            <span class="fs-5 text-danger mt-1">
                @(((int)remainingTime.TotalMinutes).ToString("D2")):@(remainingTime.Seconds.ToString("D2"))
            </span>
            <span class="small text-muted">倒计时</span>
        }
    }
    else
    {
        <span class="fs-2 text-secondary">关</span>
        <span class="fs-6 text-muted">热水器</span>
    }
    
    @if (WaterHeaterTimerService.LastTurnedOnDateTime is not null)
    {
        <span class="small text-muted mt-1">上次开启:</span>
        <span class="small">@WaterHeaterTimerService.LastTurnedOnDateTime.Value.ToLocalTime().ToString("HH:mm")</span>
    }

    <div class="d-flex gap-1 align-items-center mt-auto w-100 pt-2">
        <input class="form-control form-control-sm text-center"
               type="number"
               min="1"
               max="25"
               @bind="ManualOverrideMinutes"
               @bind:event="oninput"
               aria-label="Water heater manual override minutes" />
        <button class="btn btn-danger btn-sm"
                type="button"
                @onclick="TurnOnForManualOverride">
            开启
        </button>
    </div>
</div>


@code {

    [Inject] public SwitchEntities Switches { get; set; } = null!;
    [Inject] public WaterHeaterTimerService WaterHeaterTimerService { get; set; } = null!;

    private readonly List<IDisposable> _disposables = [];
    private IDisposable? _timerDisposable;
    private int ManualOverrideMinutes { get; set; } = 10;

    protected override void OnInitialized()
    {
        _disposables.Add(Switches.WaterHeaterSwitch.StateAllChanges().Subscribe(_ => 
        {
            ManageTimer();
            InvokeAsync(StateHasChanged);
        }));
        WaterHeaterTimerService.StateChanged += OnWaterHeaterTimerStateChanged;
        ManageTimer();
    }

    public void Dispose()
    {
        WaterHeaterTimerService.StateChanged -= OnWaterHeaterTimerStateChanged;
        _timerDisposable?.Dispose();
        _disposables.ForEach(e => e.Dispose());
    }

    private void ManageTimer()
    {
        if (Switches.WaterHeaterSwitch.IsOn() && RemainingTime != null)
        {
            _timerDisposable ??= Observable.Interval(TimeSpan.FromSeconds(1))
                .Subscribe(_ => InvokeAsync(StateHasChanged));
        }
        else
        {
            _timerDisposable?.Dispose();
            _timerDisposable = null;
        }
    }

    private void OnWaterHeaterTimerStateChanged()
    {
        ManageTimer();
        _ = InvokeAsync(StateHasChanged);
    }

    private TimeSpan? RemainingTime
    {
        get
        {
            if (WaterHeaterTimerService.ScheduledTurnOffDateTime is not { } scheduledTurnOffDateTime)
            {
                return null;
            }

            var remainingTime = scheduledTurnOffDateTime - DateTime.UtcNow;
            return remainingTime > TimeSpan.Zero ? remainingTime : null;
        }
    }

    private void TurnOnForManualOverride()
    {
        var minutes = Math.Clamp(ManualOverrideMinutes, 1, 25);
        if (WaterHeaterTimerService.RequestManualOverride(minutes))
        {
            return;
        }

        var duration = TimeSpan.FromMinutes(minutes);
        var now = DateTime.UtcNow;

        WaterHeaterTimerService.ScheduledTurnOffDateTime = now.Add(duration);
        WaterHeaterTimerService.LastTurnedOnDateTime = now;
        Switches.WaterHeaterSwitch.TurnOn();
        Channels.Channels.TurnOffWaterHeaterSwitch.Writer.TryWrite(duration);
    }

}
