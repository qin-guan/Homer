@using System.Text.Json
@using Homer.NetDaemon.Channels
@using Homer.NetDaemon.Entities
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

<div class="d-flex w-100 h-100 justify-content-center align-items-center" style="touch-action: none;">
    <div @ref="_sliderContainer"
         class="position-relative overflow-hidden"
         style="width: 140px; height: 100%; max-height: 400px; background-color: #E1E2E8; border-radius: 40px; cursor: pointer; user-select: none;"
         @onpointerdown="OnPointerDown"
         @onpointermove="OnPointerMove"
         @onpointerup="OnPointerUp"
         @onpointercancel="OnPointerUp"
         @onpointerleave="OnPointerUp">

        @{
            var fillPercentage = GetFillPercentage();
            var fillHeight = $"{fillPercentage}%";
        }
        <!-- Fill Area (Material Primary color) -->
        <div class="position-absolute w-100"
             style="top: 0; left: 0; height: @fillHeight; background-color: @(SelectedBlinds.Any() ? "#0B57D0" : "#C4C7C5"); transition: height 0.1s linear; pointer-events: none;">
        </div>

        <!-- Position Indicators -->
        @for (int i = 0; i < 3; i++)
        {
            if (i < BlindPositions.Count)
            {
                var posPercent = (BlindPositions[i] / 3.0) * 100;
                var isSelected = SelectedBlinds.Contains(i);

                // If it is inside the filled area, we need to invert the color
                bool isInsideFill = posPercent <= fillPercentage;
                string lineColor;
                string textColor;

                if (isSelected)
                {
                    lineColor = isInsideFill ? "#FFFFFF" : "#0B57D0";
                    textColor = isInsideFill ? "#FFFFFF" : "#0B57D0";
                }
                else
                {
                    lineColor = isInsideFill ? "#F0F0F0" : "#74777F";
                    textColor = isInsideFill ? "#F0F0F0" : "#74777F";
                }

                <div class="position-absolute w-100 d-flex align-items-center" style="top: @(posPercent)%; transform: translateY(-50%); pointer-events: none; padding: 0 16px;">
                    <div style="flex-grow: 1; height: 4px; background-color: @lineColor; border-radius: 2px;"></div>
                    <span class="ms-3 fw-bold" style="color: @textColor; font-size: 1rem;">
                        @(i + 1)
                    </span>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public List<double> BlindPositions { get; set; } = [0, 0, 0];
    [Parameter] public List<int> SelectedBlinds { get; set; } = new();
    [Parameter] public EventCallback<double> OnPositionSet { get; set; }

    private ElementReference _sliderContainer;
    private bool _isDragging;
    private double? _dragPercentage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("eval", @"
                window.getBoundingClientRect = (element) => {
                    if (element) {
                        return element.getBoundingClientRect();
                    }
                    return { top: 0, height: 0 };
                };
                window.elementRef = {
                    setPointerCapture: (element, pointerId) => {
                        if (element && element.setPointerCapture) {
                            element.setPointerCapture(pointerId);
                        }
                    },
                    releasePointerCapture: (element, pointerId) => {
                        if (element && element.releasePointerCapture) {
                            element.releasePointerCapture(pointerId);
                        }
                    }
                };
            ");
        }
    }

    private double GetFillPercentage()
    {
        if (_dragPercentage.HasValue) return _dragPercentage.Value;

        if (SelectedBlinds.Count == 0 || BlindPositions.Count == 0) return 0;

        double sum = 0;
        foreach (var idx in SelectedBlinds)
        {
            if (idx < BlindPositions.Count)
                sum += BlindPositions[idx];
        }

        var avg = sum / SelectedBlinds.Count;
        return (avg / 3.0) * 100;
    }

    private async Task OnPointerDown(PointerEventArgs e)
    {
        if (SelectedBlinds.Count == 0) return;
        _isDragging = true;
        await UpdateDragPosition(e);

        try
        {
            await JSRuntime.InvokeVoidAsync("elementRef.setPointerCapture", _sliderContainer, e.PointerId);
        }
        catch { /* ignore */ }
    }

    private async Task OnPointerMove(PointerEventArgs e)
    {
        if (!_isDragging) return;
        await UpdateDragPosition(e);
    }

    private async Task OnPointerUp(PointerEventArgs e)
    {
        if (!_isDragging) return;
        _isDragging = false;
        await UpdateDragPosition(e);

        if (_dragPercentage.HasValue)
        {
            var targetPosition = (_dragPercentage.Value / 100.0) * 3.0;
            await OnPositionSet.InvokeAsync(targetPosition);
        }

        _dragPercentage = null;

        try
        {
            await JSRuntime.InvokeVoidAsync("elementRef.releasePointerCapture", _sliderContainer, e.PointerId);
        }
        catch { /* ignore */ }
    }

    private async Task UpdateDragPosition(PointerEventArgs e)
    {
        try
        {
            var rect = await JSRuntime.InvokeAsync<BoundingClientRect>("getBoundingClientRect", _sliderContainer);
            var y = e.ClientY - rect.Top;
            var height = rect.Height;

            var percentage = (y / height) * 100;
            _dragPercentage = Math.Clamp(percentage, 0, 100);
        }
        catch
        {
            _dragPercentage = null;
        }
    }

    public class BoundingClientRect
    {
        public double Top { get; set; }
        public double Height { get; set; }
    }
}
