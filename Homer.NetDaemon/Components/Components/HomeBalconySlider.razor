@using System.Text.Json
@using Homer.NetDaemon.Channels
@using Homer.NetDaemon.Entities
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

<div class="d-flex w-100 h-100 justify-content-center align-items-center" style="touch-action: none;">
    <div @ref="_sliderContainer"
         class="d-flex"
         style="width: 240px; height: 100%; max-height: 450px; background-color: #E1E2E8; border-radius: 40px; cursor: pointer; user-select: none; padding: 12px; gap: 8px; position: relative;"
         @onpointerdown="OnPointerDown"
         @onpointermove="OnPointerMove"
         @onpointerup="OnPointerUp"
         @onpointercancel="OnPointerUp"
         @onpointerleave="OnPointerUp">

        <!-- Dragging Indicator Line overlay -->
        @if (_isDragging && _dragPercentage.HasValue && SelectedBlinds.Any())
        {
            <div class="position-absolute w-100" style="top: calc(12px + @(_dragPercentage.Value)% * (100 - 24/4.5)/100); left: 0; height: 4px; background-color: #0B57D0; transform: translateY(-50%); pointer-events: none; z-index: 10; border-radius: 2px;"></div>
        }

        @for (int i = 0; i < 3; i++)
        {
            var idx = i;
            var isSelected = SelectedBlinds.Contains(idx);
            var posPercent = BlindPositions.Count > idx ? (BlindPositions[idx] / 3.0) * 100 : 0;
            var targetPercent = isSelected && _targetPercentage.HasValue ? _targetPercentage.Value : posPercent;
            if (isSelected && _isDragging && _dragPercentage.HasValue)
            {
                targetPercent = _dragPercentage.Value;
            }

            var minFill = Math.Min(posPercent, targetPercent);
            var maxFill = Math.Max(posPercent, targetPercent);
            var baseFillHeight = $"{minFill}%";
            var movingFillHeight = $"{maxFill - minFill}%";
            var movingFillTop = $"{minFill}%";

            <!-- Track for each blind -->
            <div class="flex-grow-1 position-relative overflow-hidden" style="background-color: @(isSelected ? "#D3E3FD" : "#C4C7C5"); border-radius: 28px; transition: background-color 0.2s;">

                <!-- Base Fill -->
                <div class="position-absolute w-100"
                     style="top: 0; left: 0; height: @baseFillHeight; background-color: @(isSelected ? "#0B57D0" : "#74777F"); transition: height 0.1s linear; pointer-events: none;">
                </div>

                <!-- Ghost Fill -->
                @if (Math.Abs(maxFill - minFill) > 0.5 && isSelected)
                {
                    <div class="position-absolute w-100"
                         style="top: @movingFillTop; left: 0; height: @movingFillHeight; background-color: #A8C7FA; transition: top 0.1s linear, height 0.1s linear; pointer-events: none;">
                    </div>
                }

                <!-- Label -->
                @{
                    var labelPos = Math.Clamp(posPercent, 10, 90);
                    bool isInsideBaseFill = labelPos <= minFill;
                    bool isInsideMovingFill = labelPos > minFill && labelPos <= maxFill;

                    string textColor;
                    if (isSelected)
                    {
                        if (isInsideBaseFill) textColor = "#FFFFFF";
                        else if (isInsideMovingFill) textColor = "#041E49";
                        else textColor = "#0B57D0";
                    }
                    else
                    {
                        textColor = isInsideBaseFill ? "#FFFFFF" : "#444746";
                    }
                }

                <div class="position-absolute w-100 d-flex justify-content-center align-items-center" style="top: @(labelPos)%; transform: translateY(-50%); pointer-events: none;">
                    <span class="fw-bold" style="color: @textColor; font-size: 1.2rem; transition: color 0.1s linear;">
                        @(idx + 1)
                    </span>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<double> BlindPositions { get; set; } = [0, 0, 0];
    [Parameter] public List<int> SelectedBlinds { get; set; } = new();
    [Parameter] public EventCallback<double> OnPositionSet { get; set; }

    private ElementReference _sliderContainer;
    private bool _isDragging;
    private double? _dragPercentage;
    private double? _targetPercentage;

    protected override async Task OnParametersSetAsync()
    {
        if (_targetPercentage.HasValue && SelectedBlinds.Any())
        {
            // Check if all selected blinds have reached the target
            bool allReached = true;
            foreach (var idx in SelectedBlinds)
            {
                if (idx < BlindPositions.Count)
                {
                    var currentPercent = (BlindPositions[idx] / 3.0) * 100;
                    if (Math.Abs(currentPercent - _targetPercentage.Value) > 2.0)
                    {
                        allReached = false;
                        break;
                    }
                }
            }

            if (allReached)
            {
                _targetPercentage = null;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("eval", @"
                window.getBoundingClientRect = (element) => {
                    if (element) {
                        return element.getBoundingClientRect();
                    }
                    return { top: 0, height: 0 };
                };
                window.elementRef = {
                    setPointerCapture: (element, pointerId) => {
                        if (element && element.setPointerCapture) {
                            element.setPointerCapture(pointerId);
                        }
                    },
                    releasePointerCapture: (element, pointerId) => {
                        if (element && element.releasePointerCapture) {
                            element.releasePointerCapture(pointerId);
                        }
                    }
                };
            ");
        }
    }

    private async Task OnPointerDown(PointerEventArgs e)
    {
        if (SelectedBlinds.Count == 0) return;
        _isDragging = true;

        try
        {
            _cachedRect = await JSRuntime.InvokeAsync<BoundingClientRect>("getBoundingClientRect", _sliderContainer);
        }
        catch { _cachedRect = null; }

        await UpdateDragPosition(e);

        try
        {
            await JSRuntime.InvokeVoidAsync("elementRef.setPointerCapture", _sliderContainer, e.PointerId);
        }
        catch { /* ignore */ }
    }

    private BoundingClientRect? _cachedRect;

    private Task OnPointerMove(PointerEventArgs e)
    {
        if (!_isDragging) return Task.CompletedTask;
        UpdateDragPositionSync(e);
        return Task.CompletedTask;
    }

    private async Task OnPointerUp(PointerEventArgs e)
    {
        if (!_isDragging) return;
        _isDragging = false;

        UpdateDragPositionSync(e);

        if (_dragPercentage.HasValue)
        {
            _targetPercentage = _dragPercentage.Value;
            var targetPosition = (_dragPercentage.Value / 100.0) * 3.0;
            await OnPositionSet.InvokeAsync(targetPosition);
        }

        _dragPercentage = null;
        _cachedRect = null;

        try
        {
            await JSRuntime.InvokeVoidAsync("elementRef.releasePointerCapture", _sliderContainer, e.PointerId);
        }
        catch { /* ignore */ }
    }

    private async Task UpdateDragPosition(PointerEventArgs e)
    {
        if (_cachedRect == null)
        {
            try
            {
                _cachedRect = await JSRuntime.InvokeAsync<BoundingClientRect>("getBoundingClientRect", _sliderContainer);
            }
            catch
            {
                _dragPercentage = null;
                return;
            }
        }
        UpdateDragPositionSync(e);
    }

    private void UpdateDragPositionSync(PointerEventArgs e)
    {
        if (_cachedRect == null) return;

        // Account for padding (12px top and bottom)
        var y = e.ClientY - _cachedRect.Top - 12;
        var height = _cachedRect.Height - 24;

        if (height <= 0) height = 1;

        var percentage = (y / height) * 100;
        _dragPercentage = Math.Clamp(percentage, 0, 100);
    }

    public class BoundingClientRect
    {
        public double Top { get; set; }
        public double Height { get; set; }
    }
}