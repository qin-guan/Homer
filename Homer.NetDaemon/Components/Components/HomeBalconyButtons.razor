@using System.Text.Json
@using global::NetDaemon.HassModel
@using Homer.NetDaemon.Entities
@using Homer.NetDaemon.Channels
@inject InputTextEntities InputTextEntities
@rendermode InteractiveServer

<div class="d-flex flex-column gap-3">
    <div class="d-flex justify-content-around gap-2">
        @for (int i = 0; i < 3; i++)
        {
            var idx = i;
            <div class="d-flex flex-column align-items-center gap-1">
                <input type="checkbox" class="form-check-input" style="width: 2rem; height: 2rem;"
                       checked="@_selectedBlinds.Contains(idx)"
                       @onchange="@(e => ToggleSelection(idx, e.Value))" />
                <span>Blind @(idx + 1)</span>
                @if (idx < Blinds.Count)
                {
                    <span class="text-muted small">@Math.Round(Blinds[idx], 1)</span>
                }
            </div>
        }
    </div>

    <div class="d-flex justify-content-around gap-2" style="height: 60px;">
        <button style="flex: 1;" class="btn btn-outline-primary rounded-3" @onclick="() => SendCommand(BalconyBlindAction.Up)">
            <BootstrapBlazorIcon Name="fa-solid fa-chevron-up fs-3"></BootstrapBlazorIcon>
        </button>
        <button style="flex: 1;" class="btn btn-outline-danger rounded-3" @onclick="() => SendCommand(BalconyBlindAction.Stop)">
            <BootstrapBlazorIcon Name="fa-solid fa-stop fs-3"></BootstrapBlazorIcon>
        </button>
        <button style="flex: 1;" class="btn btn-outline-primary rounded-3" @onclick="() => SendCommand(BalconyBlindAction.Down)">
            <BootstrapBlazorIcon Name="fa-solid fa-chevron-down fs-3"></BootstrapBlazorIcon>
        </button>
    </div>

    <div class="d-flex justify-content-center">
        <button class="btn btn-outline-secondary w-100" @onclick="() => SendCommand(BalconyBlindAction.Calibrate)">
            Calibrate Selected
        </button>
    </div>
</div>

@code {
    private List<int> _selectedBlinds = [0, 1, 2];

    private List<double> Blinds
    {
        get
        {
            try
            {
                return JsonSerializer.Deserialize<List<double>>(InputTextEntities.BalconyBlindsState.State ?? "[0,0,0]") ?? [0, 0, 0];
            }
            catch
            {
                return [0, 0, 0];
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        InputTextEntities.BalconyBlindsState.StateChanges().SubscribeAsync(async _ => { await InvokeAsync(StateHasChanged); });
    }

    private void ToggleSelection(int index, object? isChecked)
    {
        var val = (bool?)isChecked ?? false;
        if (val && !_selectedBlinds.Contains(index))
        {
            _selectedBlinds.Add(index);
        }
        else if (!val)
        {
            _selectedBlinds.Remove(index);
        }
    }

    private async Task SendCommand(BalconyBlindAction action)
    {
        if (_selectedBlinds.Count == 0) return;

        await BalconyBlindsChannel.Channel.Writer.WriteAsync(new BalconyBlindCommand(action, _selectedBlinds.ToList()));
    }
}
